    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Edge",
            "request": "launch",
            "type": "msedge",
//            "url": "http://localhost:80",
            "webRoot": "${workspaceFolder}", //"${workspaceFolder}/src",
            "url": "http://localhost/${relativeFile}",
            "trace": true
        },
        {
            "name": "Launch chrome",
            "request": "launch",
            "type": "chrome",
//            "url": "http://localhost:80",
            "webRoot": "${workspaceFolder}", //"${workspaceFolder}/src",
            "url": "http://localhost/${relativeFile}",
            "trace": true
        }
    ]
}